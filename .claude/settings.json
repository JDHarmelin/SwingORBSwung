{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m pytest *)",
      "Bash(python -m trading_engine *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/guard-execution.sh", "timeout": 15 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/lint-types.sh", "timeout": 60 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/run-tests.sh", "timeout": 180 }
        ]
      }
    ]
  }
}
