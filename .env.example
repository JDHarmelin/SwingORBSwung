# Copy to .env and fill in. Never commit the real .env.

# --- Market / options data provider (e.g. Polygon) ---
POLYGON_API_KEY=

# --- Telegram alert sink ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Storage ---
# SQLAlchemy URL. Default: local SQLite file.
DATABASE_URL=sqlite:///./trading_engine.db

# --- Runtime ---
LOG_LEVEL=INFO
