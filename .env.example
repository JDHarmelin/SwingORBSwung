# Copy to .env and fill in. Never commit the real .env.

# --- Market / options data provider (e.g. Polygon) ---
POLYGON_API_KEY=
# Seconds between Polygon HTTP calls (free tier ~5/min → use 12; paid can use 0.25)
POLYGON_MIN_INTERVAL_SEC=12

# --- Telegram alert sink ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Storage ---
# SQLAlchemy URL. Default: local SQLite file.
DATABASE_URL=sqlite:///./trading_engine.db

# --- Runtime ---
LOG_LEVEL=INFO
# mock | polygon (CLI --provider overrides)
DATA_PROVIDER=mock
# console | telegram (CLI --alerts overrides)
ALERT_SINK=console
